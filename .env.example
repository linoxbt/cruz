# CRUZ — Arbitrum One RPC (public — safe to ship to the browser). Only Arbitrum
# One (42161) is supported; Particle's Universal Accounts SDK has no testnet.
# A dedicated provider (Alchemy/Infura) is recommended over the public endpoint.
VITE_ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
VITE_ARBITRUM_EXPLORER=https://arbiscan.io

# Particle Network project credentials (publishable identifiers for a client-side
# SDK, not secrets). dashboard.particle.network — create a project and enable
# Universal Accounts. See REQUIREMENTS.md.
VITE_PARTICLE_PROJECT_ID=
VITE_PARTICLE_CLIENT_KEY=
VITE_PARTICLE_APP_ID=

# Starter Scaffolder delivery — GitHub/Vercel tokens are pasted by the user in
# the Scaffolder UI at generate-time, sent only for that one request, and never
# persisted or logged server-side. No env var needed here.

# ─── Wallet-funded usage/billing (AI Builder, "CRUZ Default" path only) ───
# Server-only (NO VITE_ prefix). The whole billing feature is INERT until both
# Upstash vars are set — 5 free prompts, the prepaid ledger, funding, and the
# usage dashboard all simply don't engage, and the AI Builder behaves exactly
# as it did before billing existed. BYOK is never billed regardless.
#
# Durable storage (free-prompt counts, prepaid balances, transaction history).
# Create a free Upstash Redis database (REST API): https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# The wallet that receives user funding transfers (USDC/ETH on Arbitrum One).
CRUZ_TREASURY_ADDRESS=
# Free prompts granted per connected wallet before pay-as-you-build (default 5).
BILLING_FREE_PROMPTS=
# Below-this-balance (USD cents) the dashboard nudges the user to top up.
BILLING_LOW_BALANCE_THRESHOLD_CENTS=
# Cost model. 0G reports exact per-request cost in its own settlement unit;
# this is the USD value of one whole unit (raw trace value / 1e18). LEAVE
# BLANK unless you've calibrated it against 0G's docs — when unset, cost is
# priced from token counts (the rates below) instead of the uncalibrated
# trace, so charges are never a meaningless amount from an unknown unit.
ZG_SETTLEMENT_USD_PER_UNIT=
# Per-token pricing (USD per million tokens). Used when no calibrated provider
# trace is present — the default cost path for the token-metered providers.
ANTHROPIC_COST_INPUT_PER_MTOK=
ANTHROPIC_COST_OUTPUT_PER_MTOK=
OPENAI_COST_INPUT_PER_MTOK=
OPENAI_COST_OUTPUT_PER_MTOK=
