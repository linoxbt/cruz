# CRUZ — Arbitrum One RPC (public — safe to ship to the browser). Only Arbitrum
# One (42161) is supported; Particle's Universal Accounts SDK has no testnet.
# A dedicated provider (Alchemy/Infura) is recommended over the public endpoint.
VITE_ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
VITE_ARBITRUM_EXPLORER=https://arbiscan.io

# Particle Network project credentials (publishable identifiers for a client-side
# SDK, not secrets). dashboard.particle.network — create a project and enable
# Universal Accounts. See REQUIREMENTS.md.
VITE_PARTICLE_PROJECT_ID=
VITE_PARTICLE_CLIENT_KEY=
VITE_PARTICLE_APP_ID=

# Starter Scaffolder delivery — GitHub/Vercel tokens are pasted by the user in
# the Scaffolder UI at generate-time, sent only for that one request, and never
# persisted or logged server-side. No env var needed here.
